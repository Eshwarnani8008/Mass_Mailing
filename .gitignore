# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Enterprise Platform
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment & Secrets (NEVER COMMIT THESE) ───────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging
*.env

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.coverage
.coverage
htmlcov/
.tox/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
.cache/
.parcel-cache/
.next/
.nuxt/
.output/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Database & Compiled Files ─────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.pkl
*.pyc

# ── Docker & DevOps ───────────────────────────────────────────────────────────
.dockerignore.local
docker-compose.override.yml

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Test & Coverage ───────────────────────────────────────────────────────────
.coverage
coverage.xml
htmlcov/
test-results/

# ── ML Models (large binaries — store in DVC or cloud) ───────────────────────
*.pkl
*.h5
*.model
*.joblib
services/ai-risk-engine/models/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
